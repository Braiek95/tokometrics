# ─── Database ─────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/tokometrics?schema=public"

# ─── NextAuth ─────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-random-string"
AUTH_URL="http://localhost:3000"

# ─── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Set to "false" in production after TikTok API approval
MOCK_MODE="true"

# ─── TikTok Shop API ─────────────────────────────────────
# Get from: https://partner.tiktokshop.com
TIKTOK_CLIENT_ID=""
TIKTOK_CLIENT_SECRET=""

# ─── OAuth Security ──────────────────────────────────────
# Secret for signing OAuth state (CSRF protection)
# Generate with: openssl rand -base64 32
OAUTH_STATE_SECRET="change-me-to-a-random-string"

# ─── Feishu / Lark Integration ────────────────────────────
# Webhook URL for Feishu bot notifications
FEISHU_WEBHOOK_URL=""
# Feishu App credentials (for Feishu Open API)
FEISHU_APP_ID=""
FEISHU_APP_SECRET=""
